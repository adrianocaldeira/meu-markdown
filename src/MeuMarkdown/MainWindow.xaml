<Window x:Class="MeuMarkdown.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ae="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:local="clr-namespace:MeuMarkdown"
        xmlns:controls="clr-namespace:MeuMarkdown.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Meu Markdown" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource Brush.Bg.Window}"
        AllowDrop="True"
        Drop="OnDrop" DragOver="OnDragOver">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Modern flat button style for toolbar -->
        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Secondary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Bg.Hover}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.Border.Stronger}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Bg.Active}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern tab close button -->
        <Style x:Key="TabCloseBtn" TargetType="Button">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Tertiary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Bg.Hover}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Primary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Separator style for toolbar -->
        <Style x:Key="ToolbarSep" TargetType="Border">
            <Setter Property="Width" Value="1" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Background" Value="{DynamicResource Brush.Border.Subtle}" />
        </Style>

        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />

        <!-- View mode toggle button style -->
        <Style x:Key="ViewModeBtn" TargetType="ToggleButton"
               xmlns:sys="clr-namespace:System;assembly=mscorlib">
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Secondary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Bg.Hover}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Bg.Active}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.Border.Stronger}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Primary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenFileCommand}" />
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}" />
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseTabCommand}" />
        <KeyBinding Key="Left" Modifiers="Alt" Command="{Binding GoBackCommand}" />
        <KeyBinding Key="Right" Modifiers="Alt" Command="{Binding GoForwardCommand}" />
        <KeyBinding Key="B" Modifiers="Ctrl" Command="{x:Static local:MainWindow.FormatBoldCommand}" />
        <KeyBinding Key="I" Modifiers="Ctrl" Command="{x:Static local:MainWindow.FormatItalicCommand}" />
        <KeyBinding Key="K" Modifiers="Ctrl" Command="{x:Static local:MainWindow.FormatLinkCommand}" />
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{x:Static local:MainWindow.FormatInlineCodeCommand}" />
        <KeyBinding Key="D1" Modifiers="Ctrl" Command="{x:Static local:MainWindow.FormatH1Command}" />
        <KeyBinding Key="D2" Modifiers="Ctrl" Command="{x:Static local:MainWindow.FormatH2Command}" />
        <KeyBinding Key="D3" Modifiers="Ctrl" Command="{x:Static local:MainWindow.FormatH3Command}" />
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{x:Static local:MainWindow.FormatStrikethroughCommand}" />
        <KeyBinding Key="OemPipe" Modifiers="Ctrl" Command="{x:Static local:MainWindow.ToggleSidebarCommand}" />
        <KeyBinding Key="O" Modifiers="Ctrl+Shift" Command="{x:Static local:MainWindow.OpenOutlineCommand}" />
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{x:Static local:MainWindow.FindCommand}" />
        <KeyBinding Key="H" Modifiers="Ctrl" Command="{x:Static local:MainWindow.ReplaceCommand}" />
        <KeyBinding Key="F3" Command="{x:Static local:MainWindow.FindNextCommand}" />
        <KeyBinding Key="F3" Modifiers="Shift" Command="{x:Static local:MainWindow.FindPrevCommand}" />
        <KeyBinding Key="P" Modifiers="Ctrl" Command="{x:Static local:MainWindow.QuickSwitcherCommand}" />
        <KeyBinding Key="F11" Command="{x:Static local:MainWindow.ZenModeCommand}" />
        <KeyBinding Key="F10" Command="{x:Static local:MainWindow.ZenSoloCommand}" />
        <KeyBinding Key="T" Modifiers="Ctrl+Shift" Command="{x:Static local:MainWindow.TypewriterCommand}" />
    </Window.InputBindings>

    <Grid x:Name="rootGrid">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="titleBarRow" Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="activityBarCol" Width="Auto" />
            <ColumnDefinition x:Name="sidebarCol" Width="280" />
            <ColumnDefinition x:Name="sidebarSplitterCol" Width="4" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ==================== TITLE BAR (custom chrome) ==================== -->
        <Border Grid.Row="0" Grid.ColumnSpan="4"
                Background="{DynamicResource Brush.Bg.SurfaceAlt}"
                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Window controls: min / max / close (à direita) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Click="OnMinimizeWindow" Style="{StaticResource WindowControlBtn}"
                            ToolTip="Minimizar">
                        <Path Data="M 0,6 L 10,6" Stroke="{DynamicResource Brush.Fg.Secondary}"
                              StrokeThickness="1" Width="10" Height="10"
                              VerticalAlignment="Center" />
                    </Button>
                    <Button Click="OnMaximizeRestoreWindow" Style="{StaticResource WindowControlBtn}"
                            ToolTip="Maximizar/Restaurar">
                        <Grid>
                            <!-- Square (when normal) -->
                            <Path x:Name="MaxIconNormal" Data="M 0,0 L 10,0 L 10,10 L 0,10 Z"
                                  Stroke="{DynamicResource Brush.Fg.Secondary}" StrokeThickness="1"
                                  Fill="Transparent" Width="10" Height="10" />
                            <!-- Overlapping squares (when maximized) -->
                            <Path x:Name="MaxIconRestore" Visibility="Collapsed"
                                  Data="M 2,0 L 10,0 L 10,8 L 8,8 L 8,2 L 2,2 Z M 0,2 L 8,2 M 0,2 L 0,10 L 8,10 L 8,2"
                                  Stroke="{DynamicResource Brush.Fg.Secondary}" StrokeThickness="1"
                                  Fill="Transparent" Width="10" Height="10" />
                        </Grid>
                    </Button>
                    <Button Click="OnCloseWindow" Style="{StaticResource WindowCloseBtn}"
                            ToolTip="Fechar">
                        <controls:Icon Geometry="{StaticResource Icon.X}" Size="10" />
                    </Button>
                </StackPanel>

                <!-- App brand + Menu bar (à esquerda) -->
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Resources/app-icon.ico" Width="14" Height="14"
                           Margin="12,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Meu Markdown" FontSize="12"
                               Foreground="{DynamicResource Brush.Fg.Secondary}"
                               VerticalAlignment="Center" Margin="0,0,14,0" />

                    <!-- Menu Bar integrada à title bar -->
                    <Menu x:Name="menuBar" Background="Transparent" BorderThickness="0"
                          FontSize="13" Foreground="{DynamicResource Brush.Fg.Secondary}"
                          shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <MenuItem Header="_Arquivo">
                    <MenuItem Header="_Abrir..." Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O">
                        <MenuItem.Icon>
                            <controls:Icon Geometry="{StaticResource Icon.FolderOpen}" Size="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="_Salvar" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S">
                        <MenuItem.Icon>
                            <controls:Icon Geometry="{StaticResource Icon.Save}" Size="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="E_xportar">
                        <MenuItem.Icon>
                            <controls:Icon Geometry="{StaticResource Icon.Upload}" Size="14" />
                        </MenuItem.Icon>
                        <MenuItem Header="HTML..." Click="OnExportHtml" />
                        <MenuItem Header="PDF..." Click="OnExportPdf" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="_Fechar aba" Command="{Binding CloseTabCommand}" InputGestureText="Ctrl+W">
                        <MenuItem.Icon>
                            <controls:Icon Geometry="{StaticResource Icon.X}" Size="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Sa_ir" Click="OnExit">
                        <MenuItem.Icon>
                            <controls:Icon Geometry="{StaticResource Icon.LogOut}" Size="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="_Navegar">
                    <MenuItem Header="_Voltar" Command="{Binding GoBackCommand}" InputGestureText="Alt+Left">
                        <MenuItem.Icon>
                            <controls:Icon Geometry="{StaticResource Icon.ArrowLeft}" Size="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="_Avançar" Command="{Binding GoForwardCommand}" InputGestureText="Alt+Right">
                        <MenuItem.Icon>
                            <controls:Icon Geometry="{StaticResource Icon.ArrowRight}" Size="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="_Exibir">
                    <MenuItem Header="Modo _Visualização" x:Name="viewModeMenuItem" IsCheckable="True"
                              Click="OnToggleViewMode" InputGestureText="F5">
                        <MenuItem.Icon>
                            <controls:Icon Geometry="{StaticResource Icon.Eye}" Size="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Tema _Escuro" x:Name="darkThemeMenuItem" IsCheckable="True"
                              Click="OnToggleDarkTheme" InputGestureText="F6">
                        <MenuItem.Icon>
                            <controls:Icon Geometry="{StaticResource Icon.Moon}" Size="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Sincronizar _scroll" x:Name="syncScrollMenuItem"
                              IsCheckable="True" Click="OnToggleSyncScroll">
                        <MenuItem.Icon>
                            <controls:Icon Geometry="{StaticResource Icon.ArrowUpDown}" Size="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="_Typewriter mode" x:Name="typewriterMenuItem"
                              IsCheckable="True" Click="OnToggleTypewriter"
                              InputGestureText="Ctrl+Shift+T">
                        <MenuItem.Icon>
                            <controls:Icon Geometry="{StaticResource Icon.Keyboard}" Size="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="_Zen mode" Click="OnToggleZen" InputGestureText="F11">
                        <MenuItem.Icon>
                            <controls:Icon Geometry="{StaticResource Icon.Maximize}" Size="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Alternar _Sidebar" Click="OnToggleSidebar" InputGestureText="Ctrl+\">
                        <MenuItem.Icon>
                            <controls:Icon Geometry="{StaticResource Icon.PanelLeft}" Size="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="Ferr_amentas">
                    <MenuItem Header="Definir ._md como padrão" Click="OnSetAsDefault">
                        <MenuItem.Icon>
                            <controls:Icon Geometry="{StaticResource Icon.Settings2}" Size="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="A_juda">
                    <MenuItem Header="_Verificar atualizações..." Click="OnCheckForUpdates">
                        <MenuItem.Icon>
                            <controls:Icon Geometry="{StaticResource Icon.RefreshCw}" Size="14" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="_Sobre Meu Markdown" Click="OnShowAbout" />
                </MenuItem>
                    </Menu>
                </StackPanel>
            </DockPanel>
        </Border>
        <!-- ==================== /TITLE BAR ==================== -->

        <!-- Activity Bar (Row 1, sob title bar) -->
        <controls:ActivityBar x:Name="activityBar" Grid.Row="1" Grid.Column="0" />

        <!-- Sidebar Panel host -->
        <controls:SidebarHost x:Name="sidebarHost" Grid.Row="1" Grid.Column="1" />

        <!-- Splitter para resize da sidebar -->
        <GridSplitter Grid.Row="1" Grid.Column="2" Width="4" HorizontalAlignment="Stretch"
                      Background="Transparent" Cursor="SizeWE"
                      DragCompleted="OnSidebarSplitterDragCompleted" />

        <!-- Coluna principal: toolbar, tabs, editor+preview, status (menu agora na title bar) -->
        <Grid Grid.Row="1" Grid.Column="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Modern Formatting Toolbar -->
            <Border Grid.Row="0" x:Name="toolbarBorder" Background="{DynamicResource Brush.Bg.SurfaceAlt}"
                    BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="0,0,0,1" Padding="6,4">
                <WrapPanel x:Name="toolbarPanel">
                    <!-- View Mode Toggle -->
                    <ToggleButton x:Name="viewModeToggle" Style="{StaticResource ViewModeBtn}"
                                  ToolTip="Modo Visualização (F5)" Click="OnToggleViewModeButton">
                        <controls:Icon Geometry="{StaticResource Icon.Eye}" Size="15" />
                    </ToggleButton>
                    <Border Style="{StaticResource ToolbarSep}" />

                    <!-- Headings -->
                    <Button Click="OnFormatH1" ToolTip="Heading 1 (Ctrl+1)" Style="{StaticResource ToolbarBtn}"
                            FontWeight="Bold" FontSize="15" Content="H1" />
                    <Button Click="OnFormatH2" ToolTip="Heading 2 (Ctrl+2)" Style="{StaticResource ToolbarBtn}"
                            FontWeight="Bold" FontSize="13" Content="H2" />
                    <Button Click="OnFormatH3" ToolTip="Heading 3 (Ctrl+3)" Style="{StaticResource ToolbarBtn}"
                            FontWeight="Bold" FontSize="11" Content="H3" />
                    <Border Style="{StaticResource ToolbarSep}" />

                    <!-- Text formatting -->
                    <Button Click="OnFormatBold" ToolTip="Negrito (Ctrl+B)" Style="{StaticResource ToolbarBtn}"
                            FontWeight="Bold" FontSize="14" Content="B" />
                    <Button Click="OnFormatItalic" ToolTip="Itálico (Ctrl+I)" Style="{StaticResource ToolbarBtn}"
                            FontStyle="Italic" FontFamily="Georgia" FontSize="14" Content="I" />
                    <Button Click="OnFormatStrikethrough" ToolTip="Tachado (Ctrl+Shift+S)" Style="{StaticResource ToolbarBtn}">
                        <TextBlock TextDecorations="Strikethrough" Text="S" FontSize="13" />
                    </Button>
                    <Border Style="{StaticResource ToolbarSep}" />

                    <!-- Links and images -->
                    <Button Click="OnFormatLink" ToolTip="Link (Ctrl+K)" Style="{StaticResource ToolbarBtn}">
                        <controls:Icon Geometry="{StaticResource Icon.Link}" Size="15" />
                    </Button>
                    <Button Click="OnFormatImage" ToolTip="Imagem" Style="{StaticResource ToolbarBtn}">
                        <controls:Icon Geometry="{StaticResource Icon.Image}" Size="15" />
                    </Button>
                    <Border Style="{StaticResource ToolbarSep}" />

                    <!-- Code -->
                    <Button Click="OnFormatInlineCode" ToolTip="Código inline (Ctrl+E)" Style="{StaticResource ToolbarBtn}">
                        <controls:Icon Geometry="{StaticResource Icon.Code}" Size="15" />
                    </Button>
                    <Button Click="OnFormatCodeBlock" ToolTip="Bloco de código" Style="{StaticResource ToolbarBtn}">
                        <controls:Icon Geometry="{StaticResource Icon.CodeBlock}" Size="15" />
                    </Button>
                    <Border Style="{StaticResource ToolbarSep}" />

                    <!-- Lists -->
                    <Button Click="OnFormatBulletList" ToolTip="Lista" Style="{StaticResource ToolbarBtn}">
                        <controls:Icon Geometry="{StaticResource Icon.List}" Size="15" />
                    </Button>
                    <Button Click="OnFormatNumberedList" ToolTip="Lista numerada" Style="{StaticResource ToolbarBtn}">
                        <controls:Icon Geometry="{StaticResource Icon.ListOrdered}" Size="15" />
                    </Button>
                    <Button Click="OnFormatCheckbox" ToolTip="Checkbox" Style="{StaticResource ToolbarBtn}">
                        <controls:Icon Geometry="{StaticResource Icon.SquareCheck}" Size="15" />
                    </Button>
                    <Border Style="{StaticResource ToolbarSep}" />

                    <!-- Block elements -->
                    <Button Click="OnFormatQuote" ToolTip="Citação" Style="{StaticResource ToolbarBtn}">
                        <controls:Icon Geometry="{StaticResource Icon.Quote}" Size="15" />
                    </Button>
                    <Button Click="OnFormatHorizontalRule" ToolTip="Linha horizontal" Style="{StaticResource ToolbarBtn}">
                        <controls:Icon Geometry="{StaticResource Icon.Minus}" Size="15" />
                    </Button>
                    <Button Click="OnFormatTable" ToolTip="Tabela" Style="{StaticResource ToolbarBtn}">
                        <controls:Icon Geometry="{StaticResource Icon.Table}" Size="15" />
                    </Button>
                </WrapPanel>
            </Border>

            <!-- Tab Strip - modern style -->
            <Border Grid.Row="1" x:Name="tabStripBorder" Background="{DynamicResource Brush.Bg.SurfaceAlt}" BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="0,0,0,1">
                <TabControl x:Name="tabControl"
                            ItemsSource="{Binding Tabs}"
                            SelectedItem="{Binding SelectedTab}"
                            SelectionChanged="OnTabSelectionChanged"
                            Padding="0" BorderThickness="0"
                            Background="Transparent"
                            Margin="4,0,0,0">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="6,4">
                                <TextBlock Text="{Binding TabTitle}" VerticalAlignment="Center"
                                           FontSize="12.5" />
                                <Button Margin="8,0,0,0"
                                        Style="{StaticResource TabCloseBtn}"
                                        Click="OnCloseTabClick"
                                        ToolTip="Fechar aba">
                                    <controls:Icon Geometry="{StaticResource Icon.X}" Size="10" />
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate />
                    </TabControl.ContentTemplate>
                </TabControl>
            </Border>

            <!-- Editor + Preview Split -->
            <Grid Grid.Row="2" x:Name="editorPreviewGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="editorColumn" Width="*" MinWidth="100" />
                    <ColumnDefinition x:Name="splitterColumn" Width="5" />
                    <ColumnDefinition x:Name="previewColumn" Width="*" MinWidth="100" />
                </Grid.ColumnDefinitions>

                <!-- Editor panel with subtle border -->
                <Border Grid.Column="0" x:Name="editorBorder" Margin="4,4,0,4"
                        Background="{DynamicResource Brush.Bg.Surface}" BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <controls:FindReplaceBar Grid.Row="0" x:Name="findBar" Visibility="Collapsed" />
                        <ae:TextEditor Grid.Row="1" x:Name="textEditor"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="14"
                                       ShowLineNumbers="True"
                                       WordWrap="True"
                                       VerticalScrollBarVisibility="Auto"
                                       HorizontalScrollBarVisibility="Auto"
                                       Padding="8,8"
                                       Background="{DynamicResource Brush.Bg.Surface}"
                                       Foreground="{DynamicResource Brush.Fg.Primary}"
                                       BorderThickness="0" />
                    </Grid>
                </Border>

                <!-- Splitter - thin modern line -->
                <GridSplitter Grid.Column="1" x:Name="gridSplitter" Width="5"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              Cursor="SizeWE" />

                <!-- Preview panel with subtle border -->
                <Border Grid.Column="2" Margin="0,4,4,4"
                        Background="{DynamicResource Brush.Bg.Surface}" BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="1" CornerRadius="6">
                    <controls:MarkdownPreview x:Name="preview" />
                </Border>
            </Grid>

            <!-- Modern Status Bar -->
            <Border Grid.Row="3" x:Name="statusBorder" Background="{DynamicResource Brush.Bg.SurfaceAlt}"
                    BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="0,1,0,0" Padding="8,3">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <TextBlock x:Name="viewModeText" Text="" FontSize="11.5" Foreground="{DynamicResource Brush.Fg.Tertiary}"
                                   Margin="0,0,16,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="lineColText" Text="Ln 1, Col 1" FontSize="11.5" Foreground="{DynamicResource Brush.Fg.Tertiary}"
                                   Margin="0,0,16,0" VerticalAlignment="Center" />
                        <TextBlock Text="UTF-8" FontSize="11.5" Foreground="{DynamicResource Brush.Fg.Tertiary}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="statusText" Text="{Binding StatusText}" FontSize="11.5"
                                   Foreground="{DynamicResource Brush.Fg.Tertiary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   MaxWidth="400" />
                        <TextBlock Text=" • " FontSize="11.5" Foreground="{DynamicResource Brush.Fg.Tertiary}" VerticalAlignment="Center"
                                   Visibility="{Binding SelectedTab, Converter={StaticResource NullToCollapsedConverter}}" />
                        <TextBlock FontSize="11.5" Foreground="{DynamicResource Brush.Fg.Tertiary}" VerticalAlignment="Center"
                                   Visibility="{Binding SelectedTab, Converter={StaticResource NullToCollapsedConverter}}">
                            <Run Text="{Binding SelectedTab.WordCount, Mode=OneWay}" />
                            <Run Text="palavras" />
                            <Run Text=" • ~" />
                            <Run Text="{Binding SelectedTab.ReadingTimeMinutes, Mode=OneWay}" />
                            <Run Text="min" />
                        </TextBlock>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <controls:QuickSwitcherPopup x:Name="quickSwitcher" Grid.Row="1" Grid.ColumnSpan="4" />
    </Grid>
</Window>

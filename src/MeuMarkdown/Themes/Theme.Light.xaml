<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="Brush.Bg.Window"     Color="#fafaf9" />
    <SolidColorBrush x:Key="Brush.Bg.Surface"    Color="#ffffff" />
    <SolidColorBrush x:Key="Brush.Bg.SurfaceAlt" Color="#f5f5f4" />
    <SolidColorBrush x:Key="Brush.Bg.Hover"      Color="#f0f0ef" />
    <SolidColorBrush x:Key="Brush.Bg.Active"     Color="#e8e8e7" />
    <SolidColorBrush x:Key="Brush.Bg.Elevated"   Color="#ffffff" />

    <!-- Foregrounds -->
    <SolidColorBrush x:Key="Brush.Fg.Primary"    Color="#1c1c1b" />
    <SolidColorBrush x:Key="Brush.Fg.Secondary"  Color="#3f3f3e" />
    <SolidColorBrush x:Key="Brush.Fg.Tertiary"   Color="#78716c" />
    <SolidColorBrush x:Key="Brush.Fg.Disabled"   Color="#a8a29e" />

    <!-- Borders -->
    <SolidColorBrush x:Key="Brush.Border.Subtle"   Color="#e7e5e4" />
    <SolidColorBrush x:Key="Brush.Border.Stronger" Color="#d6d3d1" />

    <!-- Accent -->
    <SolidColorBrush x:Key="Brush.Accent.Heading" Color="#b75c2c" />
    <SolidColorBrush x:Key="Brush.Accent.Code"    Color="#6b7a36" />
    <SolidColorBrush x:Key="Brush.Accent.Link"    Color="#0969da" />

    <!-- ScrollBar -->
    <SolidColorBrush x:Key="Brush.ScrollBar.Track" Color="Transparent" />
    <SolidColorBrush x:Key="Brush.ScrollBar.Thumb" Color="#d6d3d1" />
    <SolidColorBrush x:Key="Brush.ScrollBar.ThumbHover" Color="#a8a29e" />

    <!-- Selection no editor -->
    <SolidColorBrush x:Key="Brush.Editor.Selection" Color="#add6ff" Opacity="0.6" />

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:MeuMarkdown.Controls">

    <!-- Default template for Icon custom control -->
    <Style TargetType="{x:Type controls:Icon}">
        <Setter Property="Width" Value="{Binding Size, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Height" Value="{Binding Size, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Secondary}" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Icon}">
                    <Viewbox Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"
                             Stretch="Uniform">
                        <Canvas Width="24" Height="24">
                            <Path Data="{TemplateBinding Geometry}"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="{TemplateBinding StrokeThickness}"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent" />
                        </Canvas>
                    </Viewbox>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- MenuItem default style — popups herdam cores do tema -->
    <Style TargetType="{x:Type MenuItem}">
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.Elevated}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.Bg.Hover}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Disabled}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Separator nos menus — linha sutil em vez do default branco/cinza -->
    <Style TargetType="{x:Type Separator}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                            Margin="8,3,8,3" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ContextMenu default — usado por TreeView, ListBox, etc -->
    <Style TargetType="{x:Type ContextMenu}">
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.Elevated}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- ScrollBar Thumb minimal style -->
    <Style x:Key="MeuMarkdown.ScrollBar.Thumb" TargetType="{x:Type Thumb}">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border x:Name="thumb"
                            Background="{DynamicResource Brush.ScrollBar.Thumb}"
                            CornerRadius="4"
                            Margin="2" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="thumb" Property="Background"
                                    Value="{DynamicResource Brush.ScrollBar.ThumbHover}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="thumb" Property="Background"
                                    Value="{DynamicResource Brush.ScrollBar.ThumbHover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ScrollBar global style — thin overlay, sem RepeatButtons -->
    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Background" Value="{DynamicResource Brush.ScrollBar.Track}" />
        <Setter Property="Width" Value="12" />
        <Setter Property="MinWidth" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid Background="{TemplateBinding Background}">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource MeuMarkdown.ScrollBar.Thumb}" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Height" Value="12" />
                <Setter Property="MinHeight" Value="12" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid Background="{TemplateBinding Background}">
                                <Track x:Name="PART_Track" IsDirectionReversed="False">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource MeuMarkdown.ScrollBar.Thumb}" />
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="Brush.Bg.Window"     Color="#1a1a1a" />
    <SolidColorBrush x:Key="Brush.Bg.Surface"    Color="#1e1e1e" />
    <SolidColorBrush x:Key="Brush.Bg.SurfaceAlt" Color="#161616" />
    <SolidColorBrush x:Key="Brush.Bg.Hover"      Color="#232323" />
    <SolidColorBrush x:Key="Brush.Bg.Active"     Color="#2a2a2a" />
    <SolidColorBrush x:Key="Brush.Bg.Elevated"   Color="#1f1f1f" />

    <!-- Foregrounds -->
    <SolidColorBrush x:Key="Brush.Fg.Primary"    Color="#ededed" />
    <SolidColorBrush x:Key="Brush.Fg.Secondary"  Color="#c0c0c0" />
    <SolidColorBrush x:Key="Brush.Fg.Tertiary"   Color="#888888" />
    <SolidColorBrush x:Key="Brush.Fg.Disabled"   Color="#5a5a5a" />

    <!-- Borders -->
    <SolidColorBrush x:Key="Brush.Border.Subtle"   Color="#252525" />
    <SolidColorBrush x:Key="Brush.Border.Stronger" Color="#2a2a2a" />

    <!-- Accent / destaque -->
    <SolidColorBrush x:Key="Brush.Accent.Heading" Color="#e8a87c" />
    <SolidColorBrush x:Key="Brush.Accent.Code"    Color="#b8c498" />
    <SolidColorBrush x:Key="Brush.Accent.Link"    Color="#58a6ff" />

    <!-- ScrollBar -->
    <SolidColorBrush x:Key="Brush.ScrollBar.Track" Color="Transparent" />
    <SolidColorBrush x:Key="Brush.ScrollBar.Thumb" Color="#3a3a3a" />
    <SolidColorBrush x:Key="Brush.ScrollBar.ThumbHover" Color="#4a4a4a" />

    <!-- Selection no editor -->
    <SolidColorBrush x:Key="Brush.Editor.Selection" Color="#264f78" Opacity="0.6" />

</ResourceDictionary>

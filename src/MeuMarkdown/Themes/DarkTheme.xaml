<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme colors -->
    <SolidColorBrush x:Key="DarkBackground" Color="#1e1e1e" />
    <SolidColorBrush x:Key="DarkForeground" Color="#d4d4d4" />
    <SolidColorBrush x:Key="DarkBorder" Color="#3c3c3c" />
    <SolidColorBrush x:Key="DarkMenuBackground" Color="#252526" />
    <SolidColorBrush x:Key="DarkTabBackground" Color="#2d2d2d" />
    <SolidColorBrush x:Key="DarkTabActiveBackground" Color="#1e1e1e" />
    <SolidColorBrush x:Key="DarkStatusBar" Color="#007acc" />

    <!-- Light theme colors -->
    <SolidColorBrush x:Key="LightBackground" Color="#ffffff" />
    <SolidColorBrush x:Key="LightForeground" Color="#1e1e1e" />
    <SolidColorBrush x:Key="LightBorder" Color="#e0e0e0" />
    <SolidColorBrush x:Key="LightMenuBackground" Color="#f3f3f3" />
    <SolidColorBrush x:Key="LightTabBackground" Color="#ececec" />
    <SolidColorBrush x:Key="LightTabActiveBackground" Color="#ffffff" />
    <SolidColorBrush x:Key="LightStatusBar" Color="#007acc" />

</ResourceDictionary>

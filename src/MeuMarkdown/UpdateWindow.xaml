<Window x:Class="MeuMarkdown.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MeuMarkdown.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Verificar atualizações"
        Width="500" Height="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.Bg.Window}"
        ShowInTaskbar="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            ResizeBorderThickness="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{DynamicResource Brush.Border.Stronger}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource Brush.Bg.SurfaceAlt}"
                    BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Click="OnClose" Style="{StaticResource WindowCloseBtn}"
                            ToolTip="Fechar"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <controls:Icon Geometry="{StaticResource Icon.X}" Size="10" />
                    </Button>
                    <TextBlock Text="Verificar atualizações" FontSize="12"
                               Foreground="{DynamicResource Brush.Fg.Secondary}"
                               VerticalAlignment="Center" Margin="14,0,0,0" />
                </DockPanel>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="28,24,28,16">

                <!-- Loading state -->
                <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center">
                    <TextBlock Text="Verificando atualizações..."
                               FontSize="14"
                               Foreground="{DynamicResource Brush.Fg.Secondary}"
                               HorizontalAlignment="Center" />
                    <ProgressBar IsIndeterminate="True" Height="3" Margin="0,16,0,0"
                                 Background="{DynamicResource Brush.Bg.SurfaceAlt}"
                                 Foreground="{DynamicResource Brush.Accent.Heading}"
                                 BorderThickness="0" />
                </StackPanel>

                <!-- Up to date state -->
                <StackPanel x:Name="UpToDatePanel" VerticalAlignment="Center" Visibility="Collapsed">
                    <Border Width="56" Height="56" CornerRadius="28"
                            Background="{DynamicResource Brush.Bg.Active}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Path Data="M 6,18 L 14,26 L 26,10"
                              Stroke="{DynamicResource Brush.Accent.Heading}"
                              StrokeThickness="3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Você já está na versão mais recente"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Fg.Primary}"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="UpToDateVersionText" FontSize="12"
                               FontFamily="Consolas"
                               Foreground="{DynamicResource Brush.Fg.Tertiary}"
                               HorizontalAlignment="Center" Margin="0,6,0,0" />
                </StackPanel>

                <!-- Update available state -->
                <StackPanel x:Name="UpdateAvailablePanel" VerticalAlignment="Top" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="40" Height="40" CornerRadius="20"
                                Background="{DynamicResource Brush.Bg.Active}"
                                Margin="0,0,14,0">
                            <controls:Icon Geometry="{StaticResource Icon.Upload}" Size="20"
                                           Foreground="{DynamicResource Brush.Accent.Heading}" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Nova versão disponível"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.Fg.Primary}" />
                            <TextBlock x:Name="UpdateVersionText" FontSize="12"
                                       FontFamily="Consolas"
                                       Foreground="{DynamicResource Brush.Fg.Tertiary}" Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="NOVIDADES" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Fg.Tertiary}"
                               Margin="0,8,0,6" />
                    <Border Background="{DynamicResource Brush.Bg.Surface}"
                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                            BorderThickness="1" CornerRadius="6" Padding="12,10"
                            MaxHeight="180">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="ReleaseNotesText" FontSize="12"
                                       Foreground="{DynamicResource Brush.Fg.Secondary}"
                                       TextWrapping="Wrap"
                                       FontFamily="Consolas" />
                        </ScrollViewer>
                    </Border>

                    <Border x:Name="UacWarningPanel" Visibility="Collapsed"
                            Margin="0,12,0,0" Padding="12,10"
                            Background="{DynamicResource Brush.Bg.Surface}"
                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                            BorderThickness="1" CornerRadius="6">
                        <TextBlock TextWrapping="Wrap" FontSize="11"
                                   Foreground="{DynamicResource Brush.Fg.Secondary}"
                                   Text="Esta instalação é para todos os usuários. A atualização vai pedir permissão de administrador (UAC)." />
                    </Border>
                </StackPanel>

                <!-- Error state -->
                <StackPanel x:Name="ErrorPanel" VerticalAlignment="Center" Visibility="Collapsed">
                    <Border Width="56" Height="56" CornerRadius="28"
                            Background="{DynamicResource Brush.Bg.Active}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Path Data="M 16,8 L 16,18 M 16,22 L 16,24"
                              Stroke="{DynamicResource Brush.Fg.Secondary}"
                              StrokeThickness="3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Não foi possível verificar"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Fg.Primary}"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="ErrorMessageText" FontSize="12"
                               Foreground="{DynamicResource Brush.Fg.Tertiary}"
                               HorizontalAlignment="Center" Margin="0,6,0,16"
                               TextWrapping="Wrap" TextAlignment="Center" />
                    <Button Content="Tentar novamente" Click="OnRetry"
                            HorizontalAlignment="Center" Padding="16,5"
                            MinWidth="140" />
                </StackPanel>

                <!-- Installing state -->
                <StackPanel x:Name="InstallingPanel" VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock x:Name="InstallingStatusText"
                               Text="Baixando atualização..."
                               FontSize="14"
                               Foreground="{DynamicResource Brush.Fg.Primary}"
                               HorizontalAlignment="Center" />
                    <ProgressBar x:Name="InstallingProgressBar"
                                 Minimum="0" Maximum="100" Value="0"
                                 Height="6" Margin="0,16,0,0"
                                 Background="{DynamicResource Brush.Bg.SurfaceAlt}"
                                 Foreground="{DynamicResource Brush.Accent.Heading}"
                                 BorderThickness="0" />
                    <TextBlock x:Name="InstallingDetailText" FontSize="11"
                               Foreground="{DynamicResource Brush.Fg.Tertiary}"
                               HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>

            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{DynamicResource Brush.Bg.SurfaceAlt}"
                    BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="0,1,0,0"
                    Padding="16,12">
                <DockPanel>
                    <!-- Modo: update available -->
                    <Button x:Name="DownloadBtn" DockPanel.Dock="Right" Click="OnDownload"
                            Content="Atualizar agora" Padding="20,5" MinWidth="140"
                            Margin="8,0,0,0" Visibility="Collapsed"
                            Background="{DynamicResource Brush.Bg.Active}"
                            BorderBrush="{DynamicResource Brush.Border.Stronger}" />
                    <Button x:Name="ReleaseNotesBtn" DockPanel.Dock="Right" Click="OnOpenReleasePage"
                            Content="Ver no GitHub" Padding="14,5" MinWidth="110"
                            Margin="8,0,0,0" Visibility="Collapsed" />
                    <!-- Modo: installing -->
                    <Button x:Name="CancelInstallBtn" DockPanel.Dock="Right" Click="OnCancelInstall"
                            Content="Cancelar" Padding="20,5" MinWidth="100"
                            Margin="8,0,0,0" Visibility="Collapsed" />
                    <!-- Sempre presente: fechar -->
                    <Button x:Name="CloseBtn" Content="Fechar" Click="OnClose"
                            HorizontalAlignment="Left" Padding="20,5" MinWidth="80" />
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>

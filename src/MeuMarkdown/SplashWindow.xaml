<Window x:Class="MeuMarkdown.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520" Height="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True">

    <Border CornerRadius="12" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="6" Opacity="0.45" />
        </Border.Effect>

        <Grid>
            <!-- Background gradient -->
            <Border CornerRadius="12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0f172a" Offset="0" />
                        <GradientStop Color="#1e293b" Offset="0.5" />
                        <GradientStop Color="#0f172a" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Subtle top accent line -->
            <Border VerticalAlignment="Top" Height="3" CornerRadius="12,12,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#3b82f6" Offset="0" />
                        <GradientStop Color="#8b5cf6" Offset="0.5" />
                        <GradientStop Color="#06b6d4" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Content -->
            <Grid Margin="48,36,48,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Logo + App name -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top">
                    <!-- Icon placeholder — M in circle -->
                    <Border Width="52" Height="52" CornerRadius="10" Margin="0,0,16,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2563eb" Offset="0" />
                                <GradientStop Color="#7c3aed" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="M" FontSize="28" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontFamily="Segoe UI" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Meu Markdown" FontSize="26" FontWeight="Bold"
                                   Foreground="White" FontFamily="Segoe UI" />
                        <TextBlock Text="Editor e Visualizador Markdown" FontSize="12"
                                   Foreground="#94a3b8" FontFamily="Segoe UI" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <!-- Description -->
                <TextBlock Grid.Row="1" VerticalAlignment="Center"
                           TextWrapping="Wrap" FontSize="13" FontFamily="Segoe UI"
                           Foreground="#cbd5e1" LineHeight="22" Margin="0,20,0,0">
                    Edite e visualize arquivos Markdown com preview ao vivo,
syntax highlighting, navegação entre arquivos linkados,
toolbar de formatação e suporte a múltiplas abas.
                </TextBlock>

                <!-- Progress bar -->
                <ProgressBar Grid.Row="2" x:Name="progressBar"
                             Height="3" Margin="0,16,0,12"
                             Background="#1e3a5f"
                             BorderThickness="0"
                             IsIndeterminate="True">
                    <ProgressBar.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#3b82f6" Offset="0" />
                            <GradientStop Color="#8b5cf6" Offset="1" />
                        </LinearGradientBrush>
                    </ProgressBar.Foreground>
                </ProgressBar>

                <!-- Version -->
                <TextBlock Grid.Row="3" x:Name="statusText"
                           Text="Iniciando..." FontSize="11" Foreground="#64748b"
                           FontFamily="Segoe UI" Margin="0,0,0,12" />

                <!-- Footer: copyright + version -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="© 2026 Adriano Caldeira" FontSize="11"
                                   Foreground="#94a3b8" FontFamily="Segoe UI" />
                    </StackPanel>

                    <!-- Version badge -->
                    <Border Grid.Column="1" Background="#1e293b" CornerRadius="4"
                            BorderBrush="#334155" BorderThickness="1" Padding="8,2">
                        <TextBlock x:Name="versionText" FontSize="10.5" FontFamily="Consolas"
                                   Foreground="#64748b" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>

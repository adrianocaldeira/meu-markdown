<UserControl x:Class="MeuMarkdown.Controls.Panels.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#6b7280" />
            <Setter Property="Margin" Value="0,16,0,6" />
        </Style>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="12,8,12,12">
            <TextBlock Text="CONFIGURAÇÕES" FontSize="11" FontWeight="SemiBold" Foreground="#6b7280" Margin="0,0,0,4" />

            <TextBlock Style="{StaticResource SectionHeader}" Text="EDITOR" />
            <CheckBox x:Name="SyncScrollCheck" Content="Sincronizar scroll editor↔preview" Margin="0,4" Click="OnSyncScrollChanged" />
            <CheckBox x:Name="TypewriterCheck" Content="Typewriter mode (caret centralizado)" Margin="0,4" Click="OnTypewriterChanged" />

            <TextBlock Style="{StaticResource SectionHeader}" Text="EXPLORER" />
            <CheckBox x:Name="ShowAllFilesCheck" Content="Mostrar todos os arquivos (não só .md)" Margin="0,4" Click="OnShowAllFilesChanged" />

            <TextBlock Style="{StaticResource SectionHeader}" Text="WORKSPACE" />
            <TextBlock x:Name="WorkspaceText" Style="{StaticResource SettingLabel}" Text="Nenhum workspace" TextTrimming="CharacterEllipsis" />
            <Button x:Name="ChangeWorkspaceBtn" Content="Trocar pasta..." HorizontalAlignment="Left" Margin="0,4,0,0" Padding="8,2" Click="OnChangeWorkspace" />

            <TextBlock Style="{StaticResource SectionHeader}" Text="ARQUIVOS RECENTES" />
            <TextBlock x:Name="RecentCountText" Style="{StaticResource SettingLabel}" Text="0 arquivos" />
            <Button x:Name="ClearRecentsBtn" Content="Limpar lista" HorizontalAlignment="Left" Margin="0,4,0,0" Padding="8,2" Click="OnClearRecents" />

            <TextBlock Style="{StaticResource SectionHeader}" Text="SOBRE" />
            <TextBlock Style="{StaticResource SettingLabel}" Text="Meu Markdown — editor .NET 9 WPF" />
            <TextBlock Style="{StaticResource SettingLabel}" Text="Markdig · AvalonEdit · WebView2" />
        </StackPanel>
    </ScrollViewer>
</UserControl>

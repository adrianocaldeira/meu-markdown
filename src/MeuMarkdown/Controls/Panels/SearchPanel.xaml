<UserControl x:Class="MeuMarkdown.Controls.Panels.SearchPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:MeuMarkdown.Services"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="ToggleOpt" TargetType="ToggleButton">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#e5e7eb" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#dbeafe" />
                                <Setter Property="Foreground" Value="#1d4ed8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="BUSCAR" FontSize="11" FontWeight="SemiBold"
                   Foreground="#6b7280" Margin="12,12,12,8" />

        <DockPanel Grid.Row="1" Margin="12,0,12,4">
            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleOpt}" x:Name="WholeWordToggle"
                          Content="⌐|" ToolTip="Palavra inteira" Checked="OnOptionChanged" Unchecked="OnOptionChanged" />
            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleOpt}" x:Name="RegexToggle"
                          Content=".*" ToolTip="Regex" Checked="OnOptionChanged" Unchecked="OnOptionChanged" />
            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleOpt}" x:Name="CaseToggle"
                          Content="Aa" ToolTip="Diferenciar maiúsc./minúsc." Checked="OnOptionChanged" Unchecked="OnOptionChanged" />
            <TextBox x:Name="QueryBox" FontSize="13" Padding="4,2" Margin="0,0,4,0"
                     KeyDown="OnQueryKeyDown" />
        </DockPanel>

        <TextBlock Grid.Row="2" x:Name="StatusText" Text="" FontSize="11" Foreground="#6b7280"
                   Margin="12,4,12,4" />

        <TreeView Grid.Row="3" x:Name="ResultsTree" BorderThickness="0" Background="Transparent"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  MouseLeftButtonUp="OnResultClick">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="True" />
                    <Setter Property="Padding" Value="0,1" />
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type services:FileSearchResult}" ItemsSource="{Binding Matches}">
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <TextBlock Text="📄" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding FilePath}" FontSize="12" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding FilePath}" />
                    </StackPanel>
                </HierarchicalDataTemplate>
                <DataTemplate DataType="{x:Type services:FileSearchMatch}">
                    <StackPanel Orientation="Horizontal" Margin="20,1,0,1">
                        <TextBlock Text="{Binding LineNumber, StringFormat={}{0}:}" FontSize="11"
                                   Foreground="#6b7280" Margin="0,0,8,0" MinWidth="32" />
                        <TextBlock Text="{Binding LineText}" FontSize="11.5"
                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding LineText}" />
                    </StackPanel>
                </DataTemplate>
            </TreeView.Resources>
        </TreeView>
    </Grid>
</UserControl>

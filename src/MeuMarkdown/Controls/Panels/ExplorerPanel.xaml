<UserControl x:Class="MeuMarkdown.Controls.Panels.ExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MeuMarkdown.Controls"
             xmlns:models="clr-namespace:MeuMarkdown.Models"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header com nome do workspace + menu (⋯) -->
        <DockPanel Grid.Row="0" Margin="14,14,10,6">
            <Button DockPanel.Dock="Right" x:Name="MenuBtn"
                    Width="22" Height="22" Background="Transparent" BorderThickness="0"
                    Cursor="Hand" Click="OnMenuClick" ToolTip="Opções do workspace"
                    Foreground="{DynamicResource Brush.Fg.Tertiary}">
                <controls:Icon Geometry="{StaticResource Icon.MoreHorizontal}" Size="14" />
                <Button.ContextMenu>
                    <ContextMenu x:Name="WorkspaceMenu">
                        <MenuItem Header="Abrir pasta..." Click="OnOpenFolder">
                            <MenuItem.Icon><controls:Icon Geometry="{StaticResource Icon.FolderOpen}" Size="14" /></MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Atualizar" Click="OnRefresh">
                            <MenuItem.Icon><controls:Icon Geometry="{StaticResource Icon.RefreshCw}" Size="14" /></MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Fechar workspace" Click="OnCloseWorkspace">
                            <MenuItem.Icon><controls:Icon Geometry="{StaticResource Icon.X}" Size="14" /></MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Mostrar todos os arquivos" x:Name="ShowAllFilesItem"
                                  IsCheckable="True" Click="OnToggleShowAll">
                            <MenuItem.Icon><controls:Icon Geometry="{StaticResource Icon.Folders}" Size="14" /></MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
            <TextBlock x:Name="WorkspaceNameText" Text="EXPLORER" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.Fg.Tertiary}" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
        </DockPanel>

        <!-- Busca embutida -->
        <Border Grid.Row="1" Margin="12,2,12,6"
                Background="{DynamicResource Brush.Bg.Elevated}"
                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                BorderThickness="1" CornerRadius="6" Padding="8,4">
            <DockPanel>
                <controls:Icon DockPanel.Dock="Left" Geometry="{StaticResource Icon.Search}" Size="13"
                               Margin="0,0,8,0" Foreground="{DynamicResource Brush.Fg.Tertiary}" />
                <TextBox x:Name="FilterBox" FontSize="12" Padding="0" BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource Brush.Fg.Primary}"
                         CaretBrush="{DynamicResource Brush.Fg.Primary}"
                         TextChanged="OnFilterChanged" />
            </DockPanel>
        </Border>

        <TreeView Grid.Row="2" x:Name="FileTree" BorderThickness="0" Background="Transparent"
                  Foreground="{DynamicResource Brush.Fg.Secondary}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  MouseDoubleClick="OnTreeDoubleClick">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="Padding" Value="0,1" />
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type models:FileNode}" ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal">
                        <controls:Icon x:Name="NodeIcon" Geometry="{StaticResource Icon.FileText}"
                                       Size="14" Margin="0,0,6,0"
                                       Foreground="{DynamicResource Brush.Fg.Tertiary}" />
                        <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.Fg.Secondary}" />
                    </StackPanel>
                    <HierarchicalDataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                            <Setter TargetName="NodeIcon" Property="Geometry"
                                    Value="{StaticResource Icon.Folder}" />
                        </DataTrigger>
                    </HierarchicalDataTemplate.Triggers>
                </HierarchicalDataTemplate>
            </TreeView.Resources>
            <TreeView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Abrir em nova aba" Click="OnOpenInNewTab" />
                    <MenuItem Header="Renomear (F2)" Click="OnRename" />
                    <MenuItem Header="Excluir" Click="OnDelete" />
                    <Separator />
                    <MenuItem Header="Revelar no Explorer" Click="OnRevealInExplorer" />
                    <MenuItem Header="Copiar caminho" Click="OnCopyPath" />
                </ContextMenu>
            </TreeView.ContextMenu>
        </TreeView>

        <TextBlock Grid.Row="2" x:Name="EmptyState"
                   Text="Nenhum workspace aberto.&#x0A;&#x0A;Abra uma pasta via menu ⋯ ou abrindo um arquivo."
                   Margin="14,4" Foreground="{DynamicResource Brush.Fg.Tertiary}"
                   FontStyle="Italic" FontSize="12"
                   TextWrapping="Wrap" Visibility="Visible" />

        <Border Grid.Row="3" Height="1"
                Background="{DynamicResource Brush.Border.Subtle}" Margin="14,8,14,4" />

        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" MaxHeight="200" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="RECENTES" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.Fg.Tertiary}" Margin="14,0,14,4" />
            <ListBox Grid.Row="1" x:Name="RecentList" BorderThickness="0" Background="Transparent"
                     Foreground="{DynamicResource Brush.Fg.Secondary}"
                     MouseDoubleClick="OnRecentDoubleClick" Margin="0,0,0,8">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="14,2" />
                        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Secondary}" />
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <controls:Icon Geometry="{StaticResource Icon.FileText}" Size="13"
                                           Margin="0,0,8,0"
                                           Foreground="{DynamicResource Brush.Fg.Tertiary}" />
                            <TextBlock Text="{Binding}" FontSize="11.5" TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding}"
                                       Foreground="{DynamicResource Brush.Fg.Secondary}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</UserControl>

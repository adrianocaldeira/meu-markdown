<UserControl x:Class="MeuMarkdown.Controls.Panels.OutlinePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MeuMarkdown.Controls.Panels"
             xmlns:models="clr-namespace:MeuMarkdown.Models"
             Background="Transparent">
    <UserControl.Resources>
        <local:IndentToMarginConverter x:Key="IndentToMarginConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="OUTLINE" FontSize="11" FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.Fg.Tertiary}" Margin="12,12,12,8" />

        <ListBox Grid.Row="1" x:Name="HeadingsList"
                 BorderThickness="0" Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 MouseLeftButtonUp="OnHeadingClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="border" Background="Transparent" Padding="0,2">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Bg.Hover}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Bg.Active}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:Heading}">
                    <TextBlock Text="{Binding Text}" FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource Brush.Fg.Secondary}"
                               Margin="{Binding Indent, Converter={StaticResource IndentToMarginConverter}}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Grid.Row="2" x:Name="EmptyState"
                   Text="Sem headings no documento" Margin="12,8,12,12"
                   Foreground="{DynamicResource Brush.Fg.Tertiary}" FontStyle="Italic" FontSize="12"
                   Visibility="Visible" />
    </Grid>
</UserControl>

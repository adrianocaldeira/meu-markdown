<Window x:Class="MeuMarkdown.Controls.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Brush.Bg.Primary}">
    <StackPanel Margin="20">
        <TextBlock x:Name="PromptText" Margin="0,0,0,10"
                   Foreground="{DynamicResource Brush.Fg.Primary}" />
        <TextBox x:Name="InputBox" Padding="6"
                 Background="{DynamicResource Brush.Bg.Secondary}"
                 Foreground="{DynamicResource Brush.Fg.Primary}"
                 BorderBrush="{DynamicResource Brush.Border}"
                 BorderThickness="1"
                 CaretBrush="{DynamicResource Brush.Fg.Primary}"
                 KeyDown="OnInputKeyDown" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Click="OnOk" />
            <Button Content="Cancelar" Width="80" IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>

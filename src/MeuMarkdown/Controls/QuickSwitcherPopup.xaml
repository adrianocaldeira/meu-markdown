<UserControl x:Class="MeuMarkdown.Controls.QuickSwitcherPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Visibility="Collapsed">
    <Grid>
        <Rectangle Fill="#80000000" />

        <Border Width="600" Height="380" VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,80,0,0" Background="#ffffff" CornerRadius="8"
                BorderBrush="#e5e7eb" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.3" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0" x:Name="QueryBox" Padding="12,10" FontSize="14"
                         BorderThickness="0,0,0,1" BorderBrush="#e5e7eb"
                         TextChanged="OnQueryChanged" KeyDown="OnQueryKeyDown" />

                <ListBox Grid.Row="1" x:Name="Results" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MouseDoubleClick="OnResultDoubleClick"
                         KeyDown="OnResultKeyDown">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,6" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📄" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="13" />
                                    <TextBlock Text="{Binding RelativeDir}" FontSize="11" Foreground="#9ca3af" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>

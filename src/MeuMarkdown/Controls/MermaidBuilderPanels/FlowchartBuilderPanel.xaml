<UserControl x:Class="MeuMarkdown.Controls.MermaidBuilderPanels.FlowchartBuilderPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:mm="clr-namespace:MeuMarkdown.Models.Mermaid"
             Background="{DynamicResource Brush.Bg.Surface}"
             Foreground="{DynamicResource Brush.Fg.Primary}">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="ShapesEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="mm:FlowNodeShape" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="ArrowsEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="mm:FlowArrowType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">

            <TextBlock Text="Direção" FontWeight="SemiBold" Margin="0,0,0,4" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <RadioButton Content="TD" GroupName="dir" IsChecked="{Binding Flowchart.Direction, Converter={StaticResource EnumToBool}, ConverterParameter=TD}" Margin="0,0,8,0" />
                <RadioButton Content="LR" GroupName="dir" IsChecked="{Binding Flowchart.Direction, Converter={StaticResource EnumToBool}, ConverterParameter=LR}" Margin="0,0,8,0" />
                <RadioButton Content="BT" GroupName="dir" IsChecked="{Binding Flowchart.Direction, Converter={StaticResource EnumToBool}, ConverterParameter=BT}" Margin="0,0,8,0" />
                <RadioButton Content="RL" GroupName="dir" IsChecked="{Binding Flowchart.Direction, Converter={StaticResource EnumToBool}, ConverterParameter=RL}" />
            </StackPanel>

            <GroupBox Header="Nós" Margin="0,0,0,12">
                <StackPanel Margin="6">
                    <ListBox x:Name="NodesList"
                             ItemsSource="{Binding Flowchart.Nodes}"
                             Height="120"
                             SelectionChanged="NodesList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding Id}" FontWeight="SemiBold" />
                                    <Run Text=" — " />
                                    <Run Text="{Binding Label}" />
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="+ Adicionar" Click="OnAddNode" Margin="0,0,6,0" />
                        <Button Content="Remover" Click="OnRemoveNode" Margin="0,0,6,0" />
                        <Button Content="↑" Click="OnMoveNodeUp" Margin="0,0,6,0" Width="32" />
                        <Button Content="↓" Click="OnMoveNodeDown" Width="32" />
                    </StackPanel>

                    <StackPanel x:Name="NodeEditor" Margin="0,12,0,0"
                                IsEnabled="{Binding ElementName=NodesList, Path=SelectedItem, Converter={StaticResource NullToFalseConverter}}">
                        <TextBlock Text="ID" Margin="0,0,0,2" />
                        <TextBox Text="{Binding ElementName=NodesList, Path=SelectedItem.Id, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                        <TextBlock Text="Label" Margin="0,0,0,2" />
                        <TextBox Text="{Binding ElementName=NodesList, Path=SelectedItem.Label, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                        <TextBlock Text="Formato" Margin="0,0,0,2" />
                        <ComboBox ItemsSource="{Binding Source={StaticResource ShapesEnum}}"
                                  SelectedItem="{Binding ElementName=NodesList, Path=SelectedItem.Shape, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Arestas">
                <StackPanel Margin="6">
                    <ListBox x:Name="EdgesList"
                             ItemsSource="{Binding Flowchart.Edges}"
                             Height="100"
                             SelectionChanged="EdgesList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding FromId}" />
                                    <Run Text=" → " />
                                    <Run Text="{Binding ToId}" />
                                    <Run Text=" " />
                                    <Run Text="{Binding Label}" FontStyle="Italic" Foreground="{DynamicResource Brush.Fg.Secondary}" />
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="+ Adicionar" Click="OnAddEdge" Margin="0,0,6,0" />
                        <Button Content="Remover" Click="OnRemoveEdge" />
                    </StackPanel>

                    <StackPanel x:Name="EdgeEditor" Margin="0,12,0,0"
                                IsEnabled="{Binding ElementName=EdgesList, Path=SelectedItem, Converter={StaticResource NullToFalseConverter}}">
                        <TextBlock Text="De" Margin="0,0,0,2" />
                        <ComboBox ItemsSource="{Binding Flowchart.Nodes}"
                                  DisplayMemberPath="Id"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding ElementName=EdgesList, Path=SelectedItem.FromId, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,0,6" />
                        <TextBlock Text="Para" Margin="0,0,0,2" />
                        <ComboBox ItemsSource="{Binding Flowchart.Nodes}"
                                  DisplayMemberPath="Id"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding ElementName=EdgesList, Path=SelectedItem.ToId, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,0,6" />
                        <TextBlock Text="Tipo" Margin="0,0,0,2" />
                        <ComboBox ItemsSource="{Binding Source={StaticResource ArrowsEnum}}"
                                  SelectedItem="{Binding ElementName=EdgesList, Path=SelectedItem.Arrow, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,0,6" />
                        <TextBlock Text="Label (apenas para Sólida c/ label)" Margin="0,0,0,2" />
                        <TextBox Text="{Binding ElementName=EdgesList, Path=SelectedItem.Label, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="MeuMarkdown.Controls.MermaidBuilderPanels.SequenceBuilderPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:mm="clr-namespace:MeuMarkdown.Models.Mermaid"
             Background="{DynamicResource Brush.Bg.Surface}"
             Foreground="{DynamicResource Brush.Fg.Primary}">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="SeqArrowsEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="mm:SequenceArrowType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="14">

            <TextBlock Text="Atores" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Fg.Primary}" Margin="0,0,0,6" />
            <ListBox x:Name="ActorsList"
                     ItemsSource="{Binding Sequence.Actors}"
                     Height="100"
                     Background="{DynamicResource Brush.Bg.Elevated}"
                     BorderBrush="{DynamicResource Brush.Border.Stronger}"
                     BorderThickness="1"
                     Foreground="{DynamicResource Brush.Fg.Primary}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding Name}" FontWeight="SemiBold" />
                            <Run Text=" " />
                            <Run Text="{Binding Alias}" Foreground="{DynamicResource Brush.Fg.Secondary}" />
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <Button Content="+ Adicionar" Click="OnAddActor" Style="{StaticResource MermaidBuilderButton}" Margin="0,0,6,0" />
                <Button Content="Remover" Click="OnRemoveActor" Style="{StaticResource MermaidBuilderButton}" Margin="0,0,6,0" />
                <Button Content="↑" Click="OnMoveActorUp" Style="{StaticResource MermaidBuilderButton}" Width="32" Margin="0,0,6,0" />
                <Button Content="↓" Click="OnMoveActorDown" Style="{StaticResource MermaidBuilderButton}" Width="32" />
            </StackPanel>

            <StackPanel x:Name="ActorEditor" Margin="0,12,0,18">
                <TextBlock Text="Nome" Style="{StaticResource MermaidBuilderLabel}" />
                <TextBox Text="{Binding ElementName=ActorsList, Path=SelectedItem.Name, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MermaidBuilderTextBox}"
                         IsEnabled="{Binding ElementName=ActorsList, Path=SelectedItem, Converter={StaticResource NullToFalseConverter}}"
                         Margin="0,0,0,8" />
                <TextBlock Text="Alias (opcional)" Style="{StaticResource MermaidBuilderLabel}" />
                <TextBox Text="{Binding ElementName=ActorsList, Path=SelectedItem.Alias, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MermaidBuilderTextBox}"
                         IsEnabled="{Binding ElementName=ActorsList, Path=SelectedItem, Converter={StaticResource NullToFalseConverter}}"
                         Margin="0,0,0,8" />
                <CheckBox Content="É ator (não participante)"
                          Foreground="{DynamicResource Brush.Fg.Primary}"
                          IsChecked="{Binding ElementName=ActorsList, Path=SelectedItem.IsActor, UpdateSourceTrigger=PropertyChanged}"
                          IsEnabled="{Binding ElementName=ActorsList, Path=SelectedItem, Converter={StaticResource NullToFalseConverter}}" />
            </StackPanel>

            <TextBlock Text="Mensagens" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Fg.Primary}" Margin="0,0,0,6" />
            <ListBox x:Name="MessagesList"
                     ItemsSource="{Binding Sequence.Messages}"
                     Height="90"
                     Background="{DynamicResource Brush.Bg.Elevated}"
                     BorderBrush="{DynamicResource Brush.Border.Stronger}"
                     BorderThickness="1"
                     Foreground="{DynamicResource Brush.Fg.Primary}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding FromActor}" />
                            <Run Text=" → " />
                            <Run Text="{Binding ToActor}" />
                            <Run Text=": " />
                            <Run Text="{Binding Label}" FontStyle="Italic" />
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <Button Content="+ Adicionar" Click="OnAddMessage" Style="{StaticResource MermaidBuilderButton}" Margin="0,0,6,0" />
                <Button Content="Remover" Click="OnRemoveMessage" Style="{StaticResource MermaidBuilderButton}" />
            </StackPanel>

            <StackPanel x:Name="MessageEditor" Margin="0,12,0,0">
                <TextBlock Text="De" Style="{StaticResource MermaidBuilderLabel}" />
                <ComboBox Style="{StaticResource MermaidBuilderComboBox}"
                          ItemsSource="{Binding Sequence.Actors}"
                          DisplayMemberPath="Name" SelectedValuePath="Name"
                          SelectedValue="{Binding ElementName=MessagesList, Path=SelectedItem.FromActor, UpdateSourceTrigger=PropertyChanged}"
                          IsEnabled="{Binding ElementName=MessagesList, Path=SelectedItem, Converter={StaticResource NullToFalseConverter}}"
                          Margin="0,0,0,8" />
                <TextBlock Text="Para" Style="{StaticResource MermaidBuilderLabel}" />
                <ComboBox Style="{StaticResource MermaidBuilderComboBox}"
                          ItemsSource="{Binding Sequence.Actors}"
                          DisplayMemberPath="Name" SelectedValuePath="Name"
                          SelectedValue="{Binding ElementName=MessagesList, Path=SelectedItem.ToActor, UpdateSourceTrigger=PropertyChanged}"
                          IsEnabled="{Binding ElementName=MessagesList, Path=SelectedItem, Converter={StaticResource NullToFalseConverter}}"
                          Margin="0,0,0,8" />
                <TextBlock Text="Tipo" Style="{StaticResource MermaidBuilderLabel}" />
                <ComboBox Style="{StaticResource MermaidBuilderComboBox}"
                          ItemsSource="{Binding Source={StaticResource SeqArrowsEnum}}"
                          SelectedItem="{Binding ElementName=MessagesList, Path=SelectedItem.Arrow, UpdateSourceTrigger=PropertyChanged}"
                          IsEnabled="{Binding ElementName=MessagesList, Path=SelectedItem, Converter={StaticResource NullToFalseConverter}}"
                          Margin="0,0,0,8" />
                <TextBlock Text="Label" Style="{StaticResource MermaidBuilderLabel}" />
                <TextBox Text="{Binding ElementName=MessagesList, Path=SelectedItem.Label, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MermaidBuilderTextBox}"
                         IsEnabled="{Binding ElementName=MessagesList, Path=SelectedItem, Converter={StaticResource NullToFalseConverter}}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="MeuMarkdown.Controls.FindReplaceBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MeuMarkdown.Controls"
             Background="{DynamicResource Brush.Bg.SurfaceAlt}" Padding="6">
    <UserControl.Resources>
        <Style x:Key="ToggleOpt" TargetType="ToggleButton">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Secondary}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Bg.Hover}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Bg.Active}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Primary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Secondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Bg.Hover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,4">
            <Button DockPanel.Dock="Right" Style="{StaticResource NavBtn}" Click="OnClose" ToolTip="Fechar (Esc)">
                <controls:Icon Geometry="{StaticResource Icon.X}" Size="12" />
            </Button>
            <TextBlock DockPanel.Dock="Right" x:Name="MatchCountText" Text="" FontSize="11"
                       Foreground="{DynamicResource Brush.Fg.Tertiary}" VerticalAlignment="Center" Margin="8,0" />
            <Button DockPanel.Dock="Right" Style="{StaticResource NavBtn}" Click="OnNext" ToolTip="Próximo (F3)">
                <controls:Icon Geometry="{StaticResource Icon.ChevronDown}" Size="12" />
            </Button>
            <Button DockPanel.Dock="Right" Style="{StaticResource NavBtn}" Click="OnPrev" ToolTip="Anterior (Shift+F3)">
                <controls:Icon Geometry="{StaticResource Icon.ChevronUp}" Size="12" />
            </Button>
            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleOpt}" x:Name="WholeWordToggle"
                          ToolTip="Palavra inteira" Checked="OnOptionChanged" Unchecked="OnOptionChanged">
                <controls:Icon Geometry="{StaticResource Icon.WholeWord}" Size="12" />
            </ToggleButton>
            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleOpt}" x:Name="RegexToggle"
                          Content=".*" ToolTip="Expressão regular" Checked="OnOptionChanged" Unchecked="OnOptionChanged" />
            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleOpt}" x:Name="CaseSensitiveToggle"
                          Content="Aa" ToolTip="Diferenciar maiúsc./minúsc." Checked="OnOptionChanged" Unchecked="OnOptionChanged" />
            <TextBox x:Name="FindBox" FontSize="13" Padding="4,2" Margin="0,0,8,0"
                     Background="{DynamicResource Brush.Bg.Elevated}"
                     Foreground="{DynamicResource Brush.Fg.Primary}"
                     CaretBrush="{DynamicResource Brush.Fg.Primary}"
                     BorderBrush="{DynamicResource Brush.Border.Subtle}"
                     TextChanged="OnFindTextChanged" KeyDown="OnFindKeyDown" />
        </DockPanel>

        <DockPanel Grid.Row="1" x:Name="ReplaceRow" Visibility="Collapsed">
            <Button DockPanel.Dock="Right" Style="{StaticResource NavBtn}" Click="OnReplaceAll"
                    Content="Todos" Width="48" ToolTip="Substituir todos" />
            <Button DockPanel.Dock="Right" Style="{StaticResource NavBtn}" Click="OnReplaceOne"
                    Content="Subst" Width="48" ToolTip="Substituir atual" />
            <TextBox x:Name="ReplaceBox" FontSize="13" Padding="4,2" Margin="0,0,8,0"
                     Background="{DynamicResource Brush.Bg.Elevated}"
                     Foreground="{DynamicResource Brush.Fg.Primary}"
                     CaretBrush="{DynamicResource Brush.Fg.Primary}"
                     BorderBrush="{DynamicResource Brush.Border.Subtle}" />
        </DockPanel>
    </Grid>
</UserControl>

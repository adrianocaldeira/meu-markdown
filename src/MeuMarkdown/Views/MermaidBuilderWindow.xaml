<Window x:Class="MeuMarkdown.Views.MermaidBuilderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:panels="clr-namespace:MeuMarkdown.Controls.MermaidBuilderPanels"
        xmlns:controls="clr-namespace:MeuMarkdown.Controls"
        xmlns:vm="clr-namespace:MeuMarkdown.ViewModels"
        Title="Construtor visual de Mermaid"
        Width="1000" Height="650"
        MinWidth="780" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Bg.Window}"
        Foreground="{DynamicResource Brush.Fg.Primary}"
        FontFamily="Inter, Segoe UI Variable Text, Segoe UI"
        FontSize="13"
        Closing="OnClosing">
    <!-- Conversores EnumToBool e NullToFalseConverter vêm de App.xaml -->

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Tipo:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox x:Name="TypeBox" Width="200" SelectionChanged="OnTypeChanged">
                <ComboBoxItem Content="Fluxograma" Tag="Flowchart" />
                <ComboBoxItem Content="Sequência" Tag="Sequence" />
            </ComboBox>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderThickness="1" BorderBrush="{DynamicResource Brush.Border.Stronger}" CornerRadius="6">
                <ContentControl x:Name="PanelHost" />
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="Transparent" />

            <Border Grid.Column="2" BorderThickness="1" BorderBrush="{DynamicResource Brush.Border.Stronger}" CornerRadius="6">
                <controls:MermaidPreviewLite x:Name="Preview" />
            </Border>
        </Grid>

        <Expander Grid.Row="2" Header="Ver código Mermaid" Margin="0,10,0,0">
            <StackPanel>
                <TextBox Text="{Binding GeneratedCode, Mode=OneWay}"
                         IsReadOnly="True"
                         FontFamily="Cascadia Mono, Consolas"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="80" MaxHeight="160"
                         Margin="0,6,0,6" />
                <Button Content="Copiar" Click="OnCopyCode" HorizontalAlignment="Left" />
            </StackPanel>
        </Expander>

        <TextBlock Grid.Row="3"
                   Text="{Binding ErrorMessage}"
                   Foreground="#c0392b"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CancelButton" Content="Cancelar" Click="OnCancel" MinWidth="92" Margin="0,0,10,0" Padding="20,9" />
            <Button x:Name="OkButton" Content="Inserir" Click="OnOk" MinWidth="92" Padding="20,9" />
        </StackPanel>
    </Grid>
</Window>

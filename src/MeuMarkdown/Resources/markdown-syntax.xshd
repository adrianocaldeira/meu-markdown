<?xml version="1.0"?>
<SyntaxDefinition name="Markdown" extensions=".md;.markdown"
                  xmlns="http://icsharpcode.net/sharpdevelop/syntaxdefinition/2008">
  <Color name="Heading" foreground="#e8a87c" fontWeight="bold" />
  <Color name="Bold" fontWeight="bold" />
  <Color name="Italic" fontStyle="italic" />
  <Color name="Code" foreground="#b8c498" />
  <Color name="Link" foreground="#58a6ff" />
  <Color name="Quote" foreground="#888888" />
  <Color name="ListMarker" foreground="#e8a87c" />
  <Color name="HorizontalRule" foreground="#888888" />

  <RuleSet>
    <!-- Headings -->
    <Span color="Heading" begin="^######\s" />
    <Span color="Heading" begin="^#####\s" />
    <Span color="Heading" begin="^####\s" />
    <Span color="Heading" begin="^###\s" />
    <Span color="Heading" begin="^##\s" />
    <Span color="Heading" begin="^#\s" />

    <!-- Code blocks -->
    <Span color="Code" multiline="true">
      <Begin>^```</Begin>
      <End>^```</End>
    </Span>

    <!-- Inline code -->
    <Span color="Code">
      <Begin>`</Begin>
      <End>`</End>
    </Span>

    <!-- Blockquote -->
    <Span color="Quote" begin="^&gt;\s" />

    <!-- Bold -->
    <Span color="Bold">
      <Begin>\*\*</Begin>
      <End>\*\*</End>
    </Span>
    <Span color="Bold">
      <Begin>__</Begin>
      <End>__</End>
    </Span>

    <!-- Italic -->
    <Span color="Italic">
      <Begin>\*</Begin>
      <End>\*</End>
    </Span>
    <Span color="Italic">
      <Begin>(?&lt;!_)_(?!_)</Begin>
      <End>(?&lt;!_)_(?!_)</End>
    </Span>

    <!-- Links [text](url) -->
    <Rule color="Link">\[.*?\]\(.*?\)</Rule>

    <!-- Images ![alt](url) -->
    <Rule color="Link">!\[.*?\]\(.*?\)</Rule>

    <!-- List markers -->
    <Rule color="ListMarker">^\s*[-*+]\s</Rule>
    <Rule color="ListMarker">^\s*\d+\.\s</Rule>

    <!-- Horizontal rule -->
    <Rule color="HorizontalRule">^---+$</Rule>
    <Rule color="HorizontalRule">^\*\*\*+$</Rule>
  </RuleSet>
</SyntaxDefinition>
